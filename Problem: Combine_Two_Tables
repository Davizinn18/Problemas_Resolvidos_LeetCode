-- LeetCode 175 - Combine Two Tables
-- Concept: LEFT JOIN
-- Difficulty: Easy
-- Language: MySQL/SQL
-- Link: https://leetcode.com/problems/combine-two-tables/

-- Code: 

select 
    Person.firstname,
    Person.lastname,
    Address.city,
    Address.state
from Person
left join Address
    on Person.personid = Address.personid;
